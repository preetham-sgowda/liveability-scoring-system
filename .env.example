# ── PostgreSQL ──
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=lss_warehouse
POSTGRES_USER=lss_user
POSTGRES_PASSWORD=lss_password

# ── CPCB AQI API ──
CPCB_API_BASE_URL=https://app.cpcbccr.com/ccr_docs/ccr_doc/api
CPCB_API_KEY=your_cpcb_api_key_here

# ── Google Earth Engine ──
GEE_SERVICE_ACCOUNT=your-service-account@project.iam.gserviceaccount.com
GEE_KEY_FILE=path/to/gee-service-account-key.json

# ── Airflow ──
AIRFLOW__CORE__EXECUTOR=LocalExecutor
AIRFLOW__DATABASE__SQL_ALCHEMY_CONN=postgresql+psycopg2://lss_user:lss_password@postgres:5432/lss_warehouse
AIRFLOW_ADMIN_PASSWORD=admin
